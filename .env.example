# ── RiskPilot AI — environment ──────────────────────────────────────────────
# Copy to .env:  cp .env.example .env
# The app runs WITHOUT an OpenAI key. DEMO_MODE serves committed fixture reports.
# Set a real key only when you want the live LLM explanation.

# ── Backend (Python math+LLM service — no browser ever calls it directly) ───
# In prod it is a public Railway URL gated by the shared secret; the Next.js
# server is its only legitimate caller.
# Prod: these live as Railway service variables (DEMO_MODE=0 + a funded key).
# See docs/DEPLOY_BACKEND.md. Locally, DEMO_MODE default-on when
# OPENAI_API_KEY is empty — serves fixture reports, no key needed.
DEMO_MODE=1

# Optional. Leave empty to stay in DEMO_MODE.
OPENAI_API_KEY=

# Pinned model snapshot (only used when a key is set and DEMO_MODE=0).
OPENAI_MODEL=gpt-5.5

# Shared secret: the ONLY caller of the Python service is the Next.js server.
# Both sides must match. Change this to any random string for local dev.
INTERNAL_SHARED_SECRET=dev-local-secret-change-me

# Where the backend listens (inside docker-compose this is the service name).
BACKEND_PORT=8000

# ── Frontend (Next.js — the ONLY public surface) ────────────────────────────
# Prod: these live as Vercel env vars (BACKEND_INTERNAL_URL = the Railway URL).
# Server-side only. Private URL of the Python service. Browser never sees this
# (never NEXT_PUBLIC_*). See docs/DEPLOY_BACKEND.md.
BACKEND_INTERNAL_URL=http://localhost:8000

# Must equal INTERNAL_SHARED_SECRET above (server-side only, never NEXT_PUBLIC_*).
INTERNAL_SHARED_SECRET_FRONTEND=dev-local-secret-change-me
