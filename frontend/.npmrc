# @vitejs/plugin-react@4.7 accepts vite ^4|^5|^6|^7, so a fresh (no-lock) `npm install`
# floats vite up to v7, whose optional @types/node peer (^20.19 || >=22.12) conflicts
# with our pinned @types/node@22.10.7. The committed lockfile installs vite@5 (peer
# ^18 || >=20), which 22.10.7 satisfies, so `npm ci` from the lock is fine — this flag
# only smooths a fresh no-lock resolve. (@vercel/speed-insights is unrelated: zero deps,
# all peers optional.) Long-term fix: bump @types/node to >=22.12 and drop this file.
legacy-peer-deps=true
