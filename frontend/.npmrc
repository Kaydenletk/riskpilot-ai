# @vercel/speed-insights declares broad optional framework peers (incl. a svelte
# plugin wanting vite@8) that false-conflict with this project's vite@5 toolchain.
# The Next entrypoint (@vercel/speed-insights/next) needs none of them. Resolve
# the optional-peer graph loosely so `npm install` succeeds locally and in CI.
legacy-peer-deps=true
